# Copy to `backend/.env` for local overrides. `manage.py runserver` works without this file
# (SQLite, dev secret key, CORS for localhost:3000 are already defaults).

# Links in password-reset emails and similar (no trailing slash)
FRONTEND_BASE_URL=http://localhost:3000

# Optional: PostgreSQL instead of SQLite (default db.sqlite3)
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/fserp

# Optional: Redis for shared cache (otherwise LocMem is fine for single-process dev)
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/1

# Production / VPS: see `env.example` in this folder for full list.
