# Optional: set these in the hosting control panel / systemd — not required in repo.
# CORS, ALLOWED_HOSTS, and FRONTEND URLs are fixed in fsms/settings.py for production.

# Required for production (gunicorn, etc.). Optional for local `manage.py runserver` / migrate / shell
# (a dev-only key is used). 32+ random characters:
# DJANGO_SECRET_KEY=

# Optional — PostgreSQL (omit to use SQLite db.sqlite3 next to manage.py):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Optional — SMTP (omit to log emails to console):
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=FS ERP <noreply@mahasoftcorporation.com>
