# Legacy location — prefer copying env/.env.example to env/.env or backend/.env
# Django reads: DJANGO_SECRET_KEY, DJANGO_DEBUG, ALLOWED_HOSTS, CORS_ORIGINS
# (see fsms/settings.py)

DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Local UI origins; add http://adib.localhost:3000 if you use tenant subdomains on localhost with DJANGO_DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://adib.localhost:3000

# --- Production example (api.mahasoftcorporation.com + UI at mahasoftcorporation.com) ---
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<long-random-string-required-when-debug-is-false>
# ALLOWED_HOSTS=api.mahasoftcorporation.com,localhost,127.0.0.1
# List every exact browser origin for the Next.js app (shell + tenant vanity subdomains). CORS has no wildcard for subdomains.
# CORS_ORIGINS=https://mahasoftcorporation.com,https://www.mahasoftcorporation.com,https://adib.mahasoftcorporation.com
# FRONTEND_BASE_URL=https://mahasoftcorporation.com
# Optional — if unset, CSRF_TRUSTED_ORIGINS defaults to CORS_ORIGINS in fsms/settings.py
# CSRF_TRUSTED_ORIGINS=https://mahasoftcorporation.com,https://www.mahasoftcorporation.com,https://adib.mahasoftcorporation.com
#
# Local Next.js against production API: include dev origins above, e.g. http://localhost:3000,http://adib.localhost:3000
#
# CORS preflight: fsms/settings.py allows custom headers (e.g. x-selected-company-id). If the browser
# still reports that header is blocked, the reverse proxy may be returning OPTIONS without those
# headers — see backend README "CORS (production)".
