# Copy to .env and adjust. Django reads the environment (use python-dotenv in manage.py if you load .env locally).

# --- Local development (defaults match relaxed settings) ---
DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=         # optional in DEBUG; required in production (32+ random chars)
# DJANGO_ALLOWED_HOSTS=     # optional in DEBUG (defaults to *); comma-separated in production

# --- Production (required when DJANGO_DEBUG=false) ---
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=your-long-random-secret-min-32-chars
# DJANGO_ALLOWED_HOSTS=api.example.com,www.example.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# --- Database (omit for SQLite file db.sqlite3) ---
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_CONN_MAX_AGE=600

# --- HTTPS behind reverse proxy ---
# DJANGO_BEHIND_HTTPS_PROXY=true
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000

# --- App ---
# DJANGO_TIME_ZONE=Asia/Dhaka
# FRONTEND_BASE_URL=https://app.example.com
# FSERP_PLATFORM_RELEASE=1.0.0
# FSERP_MAX_UPLOAD_MB=256
