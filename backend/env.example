# Optional: copy to `backend/.env` (loaded automatically) or set in systemd / the hosting panel.

# Required for production (e.g. gunicorn + WSGI). Optional for local `manage.py runserver` / migrate / shell
# (a dev-only key is used). Minimum 32 characters; use 50+ random chars for stronger Django deploy checks:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# DJANGO_SECRET_KEY=

# --- HTTPS (Django; use when the app handles TLS or you want defense-in-depth behind a proxy) ---
# Terminating SSL at nginx is common; then you may leave these unset and redirect HTTP->HTTPS in nginx.
# If Django should redirect to HTTPS: FSERP_SECURE_SSL_REDIRECT=1
# HSTS (only after HTTPS works for every host): e.g. FSERP_SECURE_HSTS_SECONDS=31536000
# FSERP_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# FSERP_SECURE_HSTS_PRELOAD=1

# --- Self-hosted VPS (your own domain) — set all that apply; comma-separated lists, no spaces required ---
# API + site hostnames only (no https://):
# DJANGO_ALLOWED_HOSTS=api.example.com,example.com,www.example.com
# Browser origins for CORS (include scheme and port if not 443/80):
# FSERP_CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
# Same origins for CSRF (forms / session auth); include https://www if you use it:
# FSERP_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# Password-reset and other links emailed to users:
# FRONTEND_BASE_URL=https://example.com
# Optional — wildcard-style tenant subdomains (Python regexes, comma-separated). Example:
# FSERP_CORS_ORIGIN_REGEXES=^https://[a-zA-Z0-9-]+\.example\.com$
# If unset, defaults include *.mahasoftcorporation.com and *.localhost (dev).

# Optional — PostgreSQL (strongly recommended for production; omit only for tiny demos):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Optional — shared cache for password-reset OTP, rate limits, and multi-worker Gunicorn (Redis):
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/1
# (REDIS_URL is accepted as an alias for DJANGO_CACHE_URL.)
# FSERP_CACHE_KEY_PREFIX=fserp_prod

# Optional — set to 1 only in automated tests (see tests/conftest.py); omit in production.
# FSERP_DISABLE_AUTH_RATELIMIT=1

# Optional — acknowledge intentional SQLite (silences fserp.W001 on `check --deploy`):
# FSERP_USE_SQLITE=1

# Optional — disable WhiteNoise static serving when nginx (or a CDN) serves STATIC_ROOT exclusively:
# FSERP_DISABLE_WHITENOISE=1

# Optional — skip automatic Master demo tenant (FS-000001) after migrate (pytest sets this via settings; use for empty staging DB):
# FSERP_SKIP_MASTER_BOOTSTRAP=1

# Optional — master template UI banners (GET /api/admin/master-company/protection-status/); locked overrides testing:
# FSERP_MASTER_COMPANY_LOCKED=1
# FSERP_MASTER_COMPANY_TESTING=1

# Optional — SMTP (omit to log emails to console):
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=FS ERP <noreply@mahasoftcorporation.com>
