# Production template for backend/.env on a Linux VPS.
# First-time setup:
#   cp backend/env.production.example backend/.env
#   nano backend/.env   # set DATABASE_URL, SMTP, etc.
#   bash scripts/setup-vps-env.sh   # validates key length; can generate DJANGO_SECRET_KEY
#
# Never commit backend/.env (gitignored).
#
# VPS ports (shared host with VIPTAP on 8000/3000): Gunicorn :8001, Next.js :3001 — see ecosystem.config.js

# --- Required (Gunicorn will not boot without a 32+ char secret) ---
# python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_50

# --- Database (PostgreSQL — required for production) ---
DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/fserp
#
# Switch from SQLite safely (on the VPS):
#   bash scripts/use-postgres-env.sh 'postgres://USER:PASSWORD@127.0.0.1:5432/fserp'
#   bash scripts/migrate-sqlite-to-postgres.sh
#
# Do NOT use FSERP_USE_SQLITE=1 on production unless temporarily debugging.

# --- Hosts & CORS (comma-separated, no spaces required) ---
DJANGO_ALLOWED_HOSTS=api.mahasoftcorporation.com,mahasoftcorporation.com,www.mahasoftcorporation.com,127.0.0.1,localhost
FSERP_CORS_ALLOWED_ORIGINS=https://mahasoftcorporation.com,https://www.mahasoftcorporation.com
FSERP_CSRF_TRUSTED_ORIGINS=https://mahasoftcorporation.com,https://www.mahasoftcorporation.com
FRONTEND_BASE_URL=https://mahasoftcorporation.com

# --- Shared cache (recommended with 3 Gunicorn workers) ---
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/1

# --- Email (password reset) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=FS ERP <noreply@mahasoftcorporation.com>

# --- Optional HTTPS hardening (usually nginx handles redirect) ---
# FSERP_SECURE_SSL_REDIRECT=1
# FSERP_SECURE_HSTS_SECONDS=31536000

# --- Release metadata (optional) ---
# FSERP_APP_VERSION=1.0.0
# GIT_COMMIT_SHA=
