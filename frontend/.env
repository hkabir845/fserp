# Next.js — single env file (used for `next dev`, `next build`, and `next start`).
# Default API: https://api.mahasoftcorporation.com
# For local Django, comment the production NEXT_PUBLIC_* lines and uncomment the local block below.

PORT=3000

NEXT_PUBLIC_API_URL=https://api.mahasoftcorporation.com
NEXT_PUBLIC_API_BASE_URL=https://api.mahasoftcorporation.com
NEXT_PUBLIC_WS_URL=wss://api.mahasoftcorporation.com
NEXT_PUBLIC_APP_SHELL_HOSTNAMES=mahasoftcorporation.com,www.mahasoftcorporation.com
NEXT_PUBLIC_APP_ORIGIN=https://mahasoftcorporation.com

NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_APP_NAME=Filling Station ERP
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# --- Local Django (optional) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# NEXT_PUBLIC_APP_SHELL_HOSTNAMES=localhost,127.0.0.1
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
