# Shared defaults. Production builds (`next build`) use this file — not `.env.development`.
# Local dev: use `next dev` with `frontend/.env.development` (http://localhost:8000). Note: `.env.local`
# and `.env.development.local` load after `.env.development` and can override API URLs — use http for Django.

PORT=3000

NEXT_PUBLIC_API_URL=https://localhost:3000 
NEXT_PUBLIC_API_BASE_URL=https://localhost:3000 
NEXT_PUBLIC_WS_URL=wss://api.mahasoftcorporation.com
NEXT_PUBLIC_APP_SHELL_HOSTNAMES=mahasoftcorporation.com,www.mahasoftcorporation.com

NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_APP_NAME=Filling Station ERP
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
