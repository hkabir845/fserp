# Loaded only for `next dev` (NODE_ENV=development). Overrides `.env` so local Django is used.
# Use http:// тАФ `runserver` speaks HTTP only; https:// causes net::ERR_SSL_PROTOCOL_ERROR.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Optional: if Django is not on :8000, set both this and ensure api.ts dev redirect matches.
# NEXT_PUBLIC_DEV_BACKEND_ORIGIN=http://localhost:8000
# Optional: from tenant.localhost, still call production API (testing).
# NEXT_PUBLIC_USE_PRODUCTION_API=true
NEXT_PUBLIC_APP_SHELL_HOSTNAMES=localhost,127.0.0.1
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
