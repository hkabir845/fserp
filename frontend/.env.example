# Copy to `.env.local` for local development (`next dev`).
# Production builds use `.env.production` (see `.env.production.example`).

PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_SHELL_HOSTNAMES=localhost,127.0.0.1

# Optional: help text / links that mention the UI origin
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
