# Loaded for `next build` and `next start` (NODE_ENV=production).
# VPS: replace API URLs with your Django origin; set NEXT_PUBLIC_APP_SHELL_HOSTNAMES to the hostname(s)
# users type in the browser (comma-separated), e.g. app.example.com,www.app.example.com
NEXT_PUBLIC_API_URL=https://api.mahasoftcorporation.com
NEXT_PUBLIC_API_BASE_URL=https://api.mahasoftcorporation.com
NEXT_PUBLIC_WS_URL=wss://api.mahasoftcorporation.com
# NEXT_PUBLIC_APP_SHELL_HOSTNAMES=app.example.com,www.app.example.com
